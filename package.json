{
  "name": "react-num-animate",
  "version": "0.1.0",
  "description": "Lightweight, dependency-free React component and hook for smoothly animating numeric values with easing, formatting, and custom rendering.",
  "keywords": [
    "react",
    "animation",
    "animated",
    "number",
    "counter",
    "count-up",
    "tween",
    "easing",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "react": "19.2.5",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cihanyakar/react-num-animate.git"
  },
  "bugs": {
    "url": "https://github.com/cihanyakar/react-num-animate/issues"
  },
  "homepage": "https://github.com/cihanyakar/react-num-animate#readme",
  "engines": {
    "node": ">=20"
  }
}
