{
  "name": "react-num-animate",
  "version": "0.1.0",
  "description": "Dependency-free React component for per-digit reel animation. Each digit slides through a 0-9 column when the value changes, with native IntersectionObserver-driven scroll reveal and full Intl.NumberFormat support.",
  "keywords": [
    "react",
    "number",
    "number-flow",
    "digit",
    "reel",
    "odometer",
    "ticker",
    "counter",
    "intl",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "storybook": "pnpm --filter ./examples/storybook dev",
    "storybook:build": "pnpm --filter ./examples/storybook build",
    "prepublishOnly": "pnpm run typecheck && pnpm run lint && pnpm run build"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/react": "19.2.14",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "eslint": "9.39.4",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-complexity": "1.0.2",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "react": "19.2.5",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cihanyakar/react-num-animate.git"
  },
  "bugs": {
    "url": "https://github.com/cihanyakar/react-num-animate/issues"
  },
  "homepage": "https://github.com/cihanyakar/react-num-animate#readme",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.18.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
